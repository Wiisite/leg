# Porta da aplicação (Easypanel costuma mapear automaticamente, mas é bom definir)
PORT=3000

# Ambiente (sempre production no servidor)
NODE_ENV=production

# URL de Conexão com o Banco de Dados (MySQL ou MariaDB)
# O Easypanel fornecerá isso ao criar o serviço de banco de dados
# Exemplo: mysql://usuario:senha@host:3306/nome_do_banco
DATABASE_URL=

# Segredo para autenticação / Sessões (Gere uma string aleatória longa)
AUTH_SECRET=

# Se usar algum serviço de S3 para imagens (opcional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
